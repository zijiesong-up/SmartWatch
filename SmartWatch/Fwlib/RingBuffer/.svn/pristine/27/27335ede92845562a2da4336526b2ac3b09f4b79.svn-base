#ifndef __DATATYPEDEF_H__
#define __DATATYPEDEF_H__

#ifndef        BOOL_DEFINE
    typedef        unsigned char    BOOL;  ///< 布尔变量
    #define        BOOL_DEFINE
#endif

#ifndef        U8_DEFINE
    typedef        unsigned char    U8;    ///< 无符号字节
    #define        U8_DEFINE
#endif

#ifndef        S8_DEFINE
    typedef        signed char      S8;    ///< 有符号字节
    #define        S8_DEFINE
#endif

#ifndef        U16_DEFINE
    typedef        unsigned short   U16;   ///< 无符号字
    #define        U16_DEFINE
#endif

#ifndef        S16_DEFINE
    typedef        signed short     S16;   ///< 有符号字
    #define        S16_DEFINE
#endif

#ifndef        U32_DEFINE
    typedef        unsigned int    U32;    ///< 无符号双字
    #define        U32_DEFINE
#endif

#ifndef        S32_DEFINE
    typedef        signed int      S32;    ///< 有符号双字
    #define        S32_DEFINE
#endif

#endif

